# Discord bot credentials
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-guild-id-here

# Channel for automatic announcements
DISCORD_ANNOUNCEMENT_CHANNEL_ID=your-channel-id-here

# How many hours before the first session to post the weekend schedule (default: 24)
SESSION_ANNOUNCEMENT_HOURS_BEFORE=24

# How often (in minutes) to poll for session results (default: 10)
SESSION_RESULT_POLL_MINUTES=10

# IANA timezone for displayed times (default: America/Toronto)
TIMEZONE=America/Toronto
