# Discord bot credentials
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-guild-id-here

# Channel for automatic announcements
DISCORD_ANNOUNCEMENT_CHANNEL_ID=your-channel-id-here

# How many hours before the first session to post the weekend schedule (default: 24)
SESSION_ANNOUNCEMENT_HOURS_BEFORE=24

# How often (in minutes) to poll for session results (default: 10)
SESSION_RESULT_POLL_MINUTES=10

# IANA timezone for displayed times (default: America/Toronto)
TIMEZONE=America/Toronto

# ─── Prediction Championship ─────────────────────────────────

# Channel for prediction announcements and leaderboard posts
DISCORD_PREDICTIONS_CHANNEL_ID=your-predictions-channel-id-here

# Minutes before session to lock predictions (default: 5)
PREDICTION_LOCK_MINUTES_BEFORE=5

# Enable sprint predictions on sprint weekends (default: true)
ENABLE_SPRINT_PREDICTIONS=true

# Enable automated "Predictions Open" and "Weekend Results" posts (default: true)
ENABLE_WEEKEND_PREDICTION_POSTS=true
